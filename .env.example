# FinAgent Environment Variable Configuration
# Copy this file to .env and fill in your credentials
# cp .env.example .env

# ==================== LLM Configuration ====================
# Supported providers: deepseek / opencode / minimax / qwen / openrouter
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek/deepseek-chat

# ==================== Channel Configuration ====================
# Enable one or more channels by setting enabled=true and filling credentials

# Feishu (Lark) — App ID + App Secret
FEISHU_ENABLED=false
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
# Feishu notification: bot sends a message on startup so you know which bot it is
FEISHU_CHAT_ID=oc_your-chat-id
FEISHU_WEBHOOK_URL=  # Optional: group custom bot webhook for deploy notifications

# WeChat (Weixin) — QR code scan (nanobot channels login weixin)
WECHAT_ENABLED=false

# DingTalk — App Key + App Secret
DINGTALK_ENABLED=false
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret

# QQ — App ID + App Secret
QQ_ENABLED=false
QQ_APP_ID=your-qq-app-id
QQ_APP_SECRET=your-qq-app-secret

# Email — IMAP/SMTP credentials
EMAIL_ENABLED=false
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=your-email@example.com
EMAIL_IMAP_PASSWORD=your-email-password
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=your-email@example.com
EMAIL_SMTP_PASSWORD=your-email-password

# Telegram — Bot token from @BotFather
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord — Bot token + Message Content intent
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=your-discord-bot-token

# WhatsApp — QR code scan (nanobot channels login whatsapp)
WHATSAPP_ENABLED=false

# Slack — Bot token + App-Level token
SLACK_ENABLED=false
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_APP_TOKEN=your-slack-app-level-token

# ==================== Database Path ====================
FINAGENT_DB_PATH=~/.finagent/finagent.db
